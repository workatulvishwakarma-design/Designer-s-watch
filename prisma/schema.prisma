generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  ADVANCE_PAID
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum AddressType {
  BILLING
  SHIPPING
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// --- Auth.js Models (NextAuth v5) ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)
  
  accounts      Account[]
  sessions      Session[]
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlist      Wishlist?
  cart          Cart?
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain Models ---

model Address {
  id           String      @id @default(cuid())
  userId       String
  type         AddressType
  firstName    String
  lastName     String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String
  phone        String?
  isDefault    Boolean     @default(false)
  
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  image       String?
  sortPriority Int      @default(0)
  visibility  Boolean   @default(true)
  
  // SEO Fields
  seoTitle       String?
  seoDescription String?
  
  products    Product[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String        @db.Text
  price       Decimal       @db.Decimal(10, 2)
  comparePrice Decimal?     @db.Decimal(10, 2)
  msrp        Decimal?      @db.Decimal(10, 2)
  status      ProductStatus @default(DRAFT)
  featured    Boolean       @default(false)
  newArrival  Boolean       @default(false)
  bestSeller  Boolean       @default(false)
  limitedEdition Boolean    @default(false)
  
  // Luxury Storytelling & Spec Expansion
  heritageText    String?   @db.Text
  storyText       String?   @db.Text
  materialDetails String?   @db.Text
  movementType    String?
  caseSize        String?
  strapDetails    String?
  warrantyInfo    String?
  specifications  Json?      // For arbitrary key-value pairs
  
  // SEO Fields
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  inventory   Inventory[]
  orderItems  OrderItem[]
  reviews     Review[]
  cartItems   CartItem[]
  wishlistItems WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  url        String
  altText    String?
  sortOrder  Int     @default(0)
  
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model Inventory {
  id         String  @id @default(cuid())
  productId  String
  sku        String  @unique
  color      String?
  size       String?
  stock      Int     @default(0)
  lowStockThreshold Int @default(5)
  
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([wishlistId, productId])
}

model Order {
  id                String        @id @default(cuid())
  userId            String
  totalAmount       Decimal       @db.Decimal(10, 2)
  status            OrderStatus   @default(PENDING)
  paymentMethod     String?       // e.g., "UPI", "CARD", "NET_BANKING", "COD", "COD_ADVANCE"
  shippingAddressId String
  couponId          String?
  internalNotes     String?       @db.Text
  
  // Tax & Shipping records
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  shippingAmount Decimal @default(0) @db.Decimal(10, 2)
  
  // ─── Payment Gateway Fields ───
  paymentStatus           PaymentStatus @default(PENDING)
  paymentGatewayOrderId   String?       // Cashfree cf_order_id
  paymentGatewayPaymentId String?       // Cashfree cf_payment_id
  paymentSessionId        String?       // Cashfree payment_session_id
  transactionRef          String?       @unique  // DW-xxx idempotency key
  
  // ─── COD Fields ───
  isCOD        Boolean  @default(false)
  advancePaid  Decimal  @default(0) @db.Decimal(10, 2)
  balanceDue   Decimal  @default(0) @db.Decimal(10, 2)
  
  // ─── Customer Contact (for guest/anonymous) ───
  customerPhone String?
  customerEmail String?
  
  // ─── Delivery ───
  deliveryETA   DateTime?
  
  user              User         @relation(fields: [userId], references: [id])
  shippingAddress   Address      @relation(fields: [shippingAddressId], references: [id])
  coupon            Coupon?      @relation(fields: [couponId], references: [id])
  items             OrderItem[]
  trackingEvents    OrderTrackingEvent[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  productId        String
  quantity         Int
  priceAtPurchase  Decimal @db.Decimal(10, 2)
  
  order            Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product @relation(fields: [productId], references: [id])
}

model OrderTrackingEvent {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  label       String?
  location    String?
  description String?
  
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model Coupon {
  id                 String       @id @default(cuid())
  code               String       @unique
  discountType       DiscountType @default(PERCENTAGE)
  discountValue      Decimal      @db.Decimal(10, 2)
  
  // Advanced Rules
  minCartAmount      Decimal? @db.Decimal(10, 2)
  maxDiscountAmount  Decimal? @db.Decimal(10, 2)
  startDate          DateTime?
  expiresAt          DateTime?
  maxUses            Int?
  usedCount          Int          @default(0)
  perUserLimit       Int?         @default(1)
  isActive           Boolean      @default(true)
  
  orders             Order[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  rating     Int      // 1 to 5
  comment    String?  @db.Text
  isApproved Boolean  @default(false)
  isFeatured Boolean  @default(false)
  adminReply String?  @db.Text
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id          String  @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactQuery {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  status    String   @default("PENDING") // PENDING, READ, RESPONDED, ARCHIVED
  internalNote String? @db.Text
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  linkUrl   String?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

// --- Enterprise Admin Extensions ---

model StoreSettings {
  id                String  @id @default("singleton")
  storeName         String  @default("Designer's Watch")
  contactEmail      String?
  contactPhone      String?
  businessAddress   String? @db.Text
  
  // Brand Assets
  logoUrl           String?
  faviconUrl        String?
  
  // Defaults & Config
  currency          String  @default("INR")
  taxLabel          String  @default("GST")
  taxRate           Decimal @default(18.0) @db.Decimal(5, 2)
  taxInclusive      Boolean @default(true)
  
  freeShippingThreshold Decimal @default(5000) @db.Decimal(10, 2)
  defaultShippingFee    Decimal @default(0) @db.Decimal(10, 2)
  
  // Global SEO Fallbacks
  defaultSeoTitle       String?
  defaultSeoDescription String?
  ogImageUrl           String?
  
  // Promotion
  announcementText     String?
  announcementActive   Boolean @default(false)
  
  updatedAt DateTime @updatedAt
}

model ContentBlock {
  id          String  @id @default(cuid())
  sectionId   String  @unique // e.g. "home-hero", "brand-story"
  title       String?
  subtitle    String?
  description String? @db.Text
  content     Json?   // flexible structure for list-items, etc.
  mediaUrl    String?
  buttonText  String?
  buttonLink  String?
  isActive    Boolean @default(true)
  
  updatedAt DateTime @updatedAt
}

model Page {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  content     String  @db.Text
  isActive    Boolean @default(true)
  
  // SEO
  seoTitle       String?
  seoDescription String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  adminName   String
  action      String   // e.g. "PRODUCT_UPDATE"
  entityType  String   // e.g. "Product"
  entityId    String?
  details     String?  @db.Text
  createdAt   DateTime @default(now())
}

// ─── Cart Tracking & Analytics ───

model CartEvent {
  id          String   @id @default(cuid())
  cartId      String   // anonymous cookie cart_id
  productSlug String
  productName String
  action      String   // "ADD" | "REMOVE" | "UPDATE_QTY"
  quantity    Int      @default(1)
  sessionData Json?    // User-agent, referrer, etc.
  createdAt   DateTime @default(now())

  @@index([cartId])
  @@index([createdAt])
}

model AbandonedCheckout {
  id          String   @id @default(cuid())
  cartId      String
  phone       String?
  email       String?
  items       Json     // Snapshot of cart items
  totalAmount Decimal  @db.Decimal(10, 2)
  stage       String   // "CONTACT" | "ADDRESS" | "PAYMENT" | "REVIEW"
  recovered   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cartId])
  @@index([recovered])
}

